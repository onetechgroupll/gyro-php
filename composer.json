{
    "name": "onetechgroupll/gyro-php",
    "description": "Gyro-PHP Web Framework",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "classmap": [
            "gyro/core/",
            "contributions/"
        ],
        "exclude-from-classmap": [
            "**/3rdparty/**",
            "**/simpletests/**"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
