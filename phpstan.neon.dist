includes:
    - phpstan-baseline.neon

parameters:
    level: 3
    paths:
        - gyro/core/
        - contributions/
    excludePaths:
        - */3rdparty/*
        - */simpletests/*
        - */simpletest/*
        - vendor/*
        # Template files (not classlike PHP)
        - */template/*.tpl.php
        - */templates/*.tpl.php
        - */templates/*/*.tpl.php
        - */templates/*/*/*.tpl.php
        # Contributions depending on unloaded external classes/interfaces
        # These cannot be analysed without their full dependency context
        - contributions/pdf/lib/components/pdfmaker.cls.php
        - contributions/sphinx/model/drivers/sphinx/
        - contributions/models.searchindex.sphinx/
        - contributions/lib.imagetools/lib/components/imagetools_impl/imagetools.imagick.cls.php
        - contributions/text.htmlpurifier/
        # Contributions depending on DAOUsers (excluded model)
        - contributions/usermanagement/
        - contributions/usermanagement.hijackaccount/
        - contributions/usermanagement.notifications/
        # Contributions depending on DAOScheduler (excluded model)
        - contributions/scheduler/
        # Depends on Users facade class and runtime config
        - contributions/javascript.cookieconsent/
    reportUnmatchedIgnoredErrors: false
